# `DATABASE_URL` is unprefixed by the sqlx/Postgres ecosystem convention.
# All other Conduit settings use the `CONDUIT_` prefix.
DATABASE_URL=postgres://conduit:conduit_secret@localhost/conduit

CONDUIT_SERVER_HOST=0.0.0.0
CONDUIT_SERVER_PORT=8080
CONDUIT_LOG_LEVEL=info

# Set to "json" for structured (newline-delimited JSON) log output.
# CONDUIT_LOG_FORMAT=json

# 32-byte AEAD master key (base64). Required. Rotate via re-encryption.
# Generate: openssl rand -base64 32
# CONDUIT_SECRETS_KEY=

# Optional knobs (defaults shown):
# CONDUIT_DB_MIN_CONNECTIONS=2
# CONDUIT_DB_MAX_CONNECTIONS=10
# CONDUIT_DB_ACQUIRE_TIMEOUT_SECS=30
# CONDUIT_DB_STATEMENT_TIMEOUT_MS=30000
# CONDUIT_JOB_EXECUTOR_POLL_MS=200
# CONDUIT_JOB_EXECUTOR_BATCH_SIZE=10
# CONDUIT_JOB_LOCK_DURATION_SECS=30
# CONDUIT_AUTH_PROVIDER=internal
