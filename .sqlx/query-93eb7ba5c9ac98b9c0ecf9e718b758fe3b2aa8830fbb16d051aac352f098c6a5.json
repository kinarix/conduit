  "query": "\n        SELECT r.id AS role_id, r.name AS role_name,\n               ur.granted_by, ur.granted_at\n        FROM user_roles ur\n        JOIN roles r ON r.id = ur.role_id\n        WHERE ur.user_id = $1\n        ORDER BY r.name\n        ",
