{
  "info": {
    "name": "Conduit",
    "description": "Process orchestration engine API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",      "value": "http://localhost:8080", "type": "string" },
    { "key": "org_id",        "value": "", "type": "string" },
    { "key": "user_id",       "value": "", "type": "string" },
    { "key": "definition_id", "value": "", "type": "string" },
    { "key": "instance_id",   "value": "", "type": "string" },
    { "key": "task_id",       "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"ok\",\n  \"database\": \"connected\",\n  \"version\": \"0.1.0\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Orgs",
      "item": [
        {
          "name": "Create Org",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('org_id', body.id);",
                  "  pm.test('org_id saved', () => pm.expect(body.id).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/orgs",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "orgs"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"slug\": \"acme\"\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": \"<uuid>\",\n  \"name\": \"Acme Corp\",\n  \"slug\": \"acme\",\n  \"created_at\": \"2024-01-01T00:00:00Z\"\n}"
            },
            {
              "name": "409 Conflict — slug taken",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"error\": \"...\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('user_id', body.id);",
                  "  pm.test('user_id saved', () => pm.expect(body.id).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"org_id\": \"{{org_id}}\",\n  \"auth_provider\": \"internal\",\n  \"email\": \"alice@acme.com\"\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": \"<uuid>\",\n  \"org_id\": \"<uuid>\",\n  \"auth_provider\": \"internal\",\n  \"email\": \"alice@acme.com\",\n  \"created_at\": \"2024-01-01T00:00:00Z\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Deployments",
      "item": [
        {
          "name": "Deploy Process (simple user task)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('definition_id', body.id);",
                  "  pm.test('definition_id saved', () => pm.expect(body.id).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/deployments",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "deployments"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"org_id\": \"{{org_id}}\",\n  \"key\": \"simple-review\",\n  \"name\": \"Simple Review Process\",\n  \"bpmn_xml\": \"<?xml version=\\\"1.0\\\"?>\\n<definitions xmlns=\\\"http://www.omg.org/spec/BPMN/20100524/MODEL\\\">\\n  <process id=\\\"proc\\\">\\n    <startEvent id=\\\"start\\\"/>\\n    <userTask id=\\\"task1\\\" name=\\\"Review Application\\\"/>\\n    <endEvent id=\\\"end\\\"/>\\n    <sequenceFlow id=\\\"sf1\\\" sourceRef=\\\"start\\\" targetRef=\\\"task1\\\"/>\\n    <sequenceFlow id=\\\"sf2\\\" sourceRef=\\\"task1\\\" targetRef=\\\"end\\\"/>\\n  </process>\\n</definitions>\"\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": \"<uuid>\",\n  \"key\": \"simple-review\",\n  \"version\": 1,\n  \"deployed_at\": \"2024-01-01T00:00:00Z\"\n}"
            },
            {
              "name": "400 Invalid BPMN",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"Parse error: ...\"\n}"
            }
          ]
        },
        {
          "name": "Deploy Process (exclusive gateway)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('definition_id', body.id);",
                  "  pm.test('definition_id saved', () => pm.expect(body.id).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/deployments",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "deployments"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"org_id\": \"{{org_id}}\",\n  \"key\": \"approval-gateway\",\n  \"name\": \"Approval with Gateway\",\n  \"bpmn_xml\": \"<?xml version=\\\"1.0\\\"?>\\n<definitions xmlns=\\\"http://www.omg.org/spec/BPMN/20100524/MODEL\\\">\\n  <process id=\\\"approval\\\">\\n    <startEvent id=\\\"start\\\"/>\\n    <userTask id=\\\"review\\\" name=\\\"Review Request\\\"/>\\n    <exclusiveGateway id=\\\"gw\\\" default=\\\"flow_reject\\\"/>\\n    <userTask id=\\\"task_approve\\\" name=\\\"Approve\\\"/>\\n    <userTask id=\\\"task_reject\\\" name=\\\"Reject\\\"/>\\n    <endEvent id=\\\"end_ok\\\"/>\\n    <endEvent id=\\\"end_ko\\\"/>\\n    <sequenceFlow id=\\\"f1\\\" sourceRef=\\\"start\\\" targetRef=\\\"review\\\"/>\\n    <sequenceFlow id=\\\"f2\\\" sourceRef=\\\"review\\\" targetRef=\\\"gw\\\"/>\\n    <sequenceFlow id=\\\"f3\\\" sourceRef=\\\"gw\\\" targetRef=\\\"task_approve\\\"><conditionExpression>approved == true</conditionExpression></sequenceFlow>\\n    <sequenceFlow id=\\\"flow_reject\\\" sourceRef=\\\"gw\\\" targetRef=\\\"task_reject\\\"/>\\n    <sequenceFlow id=\\\"f5\\\" sourceRef=\\\"task_approve\\\" targetRef=\\\"end_ok\\\"/>\\n    <sequenceFlow id=\\\"f6\\\" sourceRef=\\\"task_reject\\\" targetRef=\\\"end_ko\\\"/>\\n  </process>\\n</definitions>\"\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": \"<uuid>\",\n  \"key\": \"approval-gateway\",\n  \"version\": 1,\n  \"deployed_at\": \"2024-01-01T00:00:00Z\"\n}"
            }
          ]
        },
        {
          "name": "Deploy Process (with labels)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('definition_id', body.id);",
                  "  pm.test('definition_id saved', () => pm.expect(body.id).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/deployments",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "deployments"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"org_id\": \"{{org_id}}\",\n  \"key\": \"labelled-process\",\n  \"name\": \"Labelled Process\",\n  \"labels\": { \"team\": \"ops\", \"env\": \"staging\" },\n  \"bpmn_xml\": \"<?xml version=\\\"1.0\\\"?>\\n<definitions xmlns=\\\"http://www.omg.org/spec/BPMN/20100524/MODEL\\\">\\n  <process id=\\\"proc\\\">\\n    <startEvent id=\\\"start\\\"/>\\n    <endEvent id=\\\"end\\\"/>\\n    <sequenceFlow id=\\\"sf1\\\" sourceRef=\\\"start\\\" targetRef=\\\"end\\\"/>\\n  </process>\\n</definitions>\"\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": \"<uuid>\",\n  \"key\": \"labelled-process\",\n  \"version\": 1,\n  \"deployed_at\": \"2024-01-01T00:00:00Z\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Process Instances",
      "item": [
        {
          "name": "Start Instance",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('instance_id', body.id);",
                  "  pm.test('instance_id saved', () => pm.expect(body.id).to.be.a('string'));",
                  "  pm.test('state is running or completed', () => {",
                  "    pm.expect(body.state).to.be.oneOf(['running', 'completed']);",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/process-instances",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "process-instances"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"org_id\": \"{{org_id}}\",\n  \"definition_id\": \"{{definition_id}}\"\n}"
            }
          },
          "response": [
            {
              "name": "201 Created — running",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": \"<uuid>\",\n  \"org_id\": \"<uuid>\",\n  \"definition_id\": \"<uuid>\",\n  \"state\": \"running\",\n  \"labels\": {},\n  \"started_at\": \"2024-01-01T00:00:00Z\",\n  \"ended_at\": null\n}"
            },
            {
              "name": "201 Created — completed (Start→End process)",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": \"<uuid>\",\n  \"org_id\": \"<uuid>\",\n  \"definition_id\": \"<uuid>\",\n  \"state\": \"completed\",\n  \"labels\": {},\n  \"started_at\": \"2024-01-01T00:00:00Z\",\n  \"ended_at\": \"2024-01-01T00:00:01Z\"\n}"
            },
            {
              "name": "404 Definition not found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"error\": \"Process definition <uuid> not found\"\n}"
            }
          ]
        },
        {
          "name": "Start Instance (with labels)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('instance_id', body.id);",
                  "  pm.test('instance_id saved', () => pm.expect(body.id).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/process-instances",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "process-instances"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"org_id\": \"{{org_id}}\",\n  \"definition_id\": \"{{definition_id}}\",\n  \"labels\": { \"case_id\": \"CASE-001\", \"priority\": \"high\" }\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": \"<uuid>\",\n  \"org_id\": \"<uuid>\",\n  \"definition_id\": \"<uuid>\",\n  \"state\": \"running\",\n  \"labels\": { \"case_id\": \"CASE-001\", \"priority\": \"high\" },\n  \"started_at\": \"2024-01-01T00:00:00Z\",\n  \"ended_at\": null\n}"
            }
          ]
        },
        {
          "name": "Get Instance",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/process-instances/{{instance_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "process-instances", "{{instance_id}}"]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": \"<uuid>\",\n  \"org_id\": \"<uuid>\",\n  \"definition_id\": \"<uuid>\",\n  \"state\": \"running\",\n  \"labels\": {},\n  \"started_at\": \"2024-01-01T00:00:00Z\",\n  \"ended_at\": null\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"error\": \"Process instance <uuid> not found\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List Pending Tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.items && body.items.length > 0) {",
                  "    pm.collectionVariables.set('task_id', body.items[0].id);",
                  "    pm.test('task_id saved from first item', () => pm.expect(body.items[0].id).to.be.a('string'));",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/tasks",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks"]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"items\": [\n    {\n      \"id\": \"<uuid>\",\n      \"instance_id\": \"<uuid>\",\n      \"execution_id\": \"<uuid>\",\n      \"element_id\": \"review\",\n      \"name\": \"Review Request\",\n      \"task_type\": \"user_task\",\n      \"state\": \"pending\",\n      \"created_at\": \"2024-01-01T00:00:00Z\",\n      \"completed_at\": null\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Get Task",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "{{task_id}}"]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": \"<uuid>\",\n  \"instance_id\": \"<uuid>\",\n  \"execution_id\": \"<uuid>\",\n  \"element_id\": \"review\",\n  \"name\": \"Review Request\",\n  \"task_type\": \"user_task\",\n  \"state\": \"pending\",\n  \"created_at\": \"2024-01-01T00:00:00Z\",\n  \"completed_at\": null\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"error\": \"Task <uuid> not found\"\n}"
            }
          ]
        },
        {
          "name": "Complete Task (no variables)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/{{task_id}}/complete",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "{{task_id}}", "complete"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{}"
            }
          },
          "response": [
            {
              "name": "204 No Content",
              "status": "No Content",
              "code": 204,
              "body": ""
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"error\": \"Task <uuid> not found\"\n}"
            },
            {
              "name": "409 Conflict — already completed",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"error\": \"Task <uuid> cannot be completed: state is 'completed'\"\n}"
            }
          ]
        },
        {
          "name": "Complete Task — approved = true (gateway → Approve branch)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/{{task_id}}/complete",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "{{task_id}}", "complete"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"variables\": [\n    { \"name\": \"approved\", \"value_type\": \"boolean\", \"value\": true }\n  ]\n}"
            }
          },
          "response": [
            {
              "name": "204 No Content — next task is 'Approve'",
              "status": "No Content",
              "code": 204,
              "body": ""
            }
          ]
        },
        {
          "name": "Complete Task — approved = false (gateway → default/Reject branch)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/{{task_id}}/complete",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "{{task_id}}", "complete"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"variables\": [\n    { \"name\": \"approved\", \"value_type\": \"boolean\", \"value\": false }\n  ]\n}"
            }
          },
          "response": [
            {
              "name": "204 No Content — next task is 'Reject'",
              "status": "No Content",
              "code": 204,
              "body": ""
            }
          ]
        },
        {
          "name": "Complete Task — multiple variables",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/{{task_id}}/complete",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "{{task_id}}", "complete"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"variables\": [\n    { \"name\": \"approved\",   \"value_type\": \"boolean\", \"value\": true },\n    { \"name\": \"score\",      \"value_type\": \"integer\", \"value\": 95 },\n    { \"name\": \"reviewer\",   \"value_type\": \"string\",  \"value\": \"alice\" }\n  ]\n}"
            }
          },
          "response": [
            {
              "name": "204 No Content",
              "status": "No Content",
              "code": 204,
              "body": ""
            }
          ]
        }
      ]
    },
    {
      "name": "Exclusive Gateway — end-to-end flow",
      "description": "Run these in order. Deploy the gateway process, start an instance, list tasks, then complete the Review task with approved=true or false to see routing.",
      "item": [
        {
          "name": "1. Create Org",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('org_id', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/orgs",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "orgs"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Test Org\",\n  \"slug\": \"test-{{$randomInt}}\"\n}"
            }
          }
        },
        {
          "name": "2. Deploy Gateway Process",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('definition_id', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/deployments",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "deployments"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"org_id\": \"{{org_id}}\",\n  \"key\": \"approval-gateway-{{$randomInt}}\",\n  \"name\": \"Approval with Gateway\",\n  \"bpmn_xml\": \"<?xml version=\\\"1.0\\\"?>\\n<definitions xmlns=\\\"http://www.omg.org/spec/BPMN/20100524/MODEL\\\">\\n  <process id=\\\"approval\\\">\\n    <startEvent id=\\\"start\\\"/>\\n    <userTask id=\\\"review\\\" name=\\\"Review Request\\\"/>\\n    <exclusiveGateway id=\\\"gw\\\" default=\\\"flow_reject\\\"/>\\n    <userTask id=\\\"task_approve\\\" name=\\\"Approve\\\"/>\\n    <userTask id=\\\"task_reject\\\" name=\\\"Reject\\\"/>\\n    <endEvent id=\\\"end_ok\\\"/>\\n    <endEvent id=\\\"end_ko\\\"/>\\n    <sequenceFlow id=\\\"f1\\\" sourceRef=\\\"start\\\" targetRef=\\\"review\\\"/>\\n    <sequenceFlow id=\\\"f2\\\" sourceRef=\\\"review\\\" targetRef=\\\"gw\\\"/>\\n    <sequenceFlow id=\\\"f3\\\" sourceRef=\\\"gw\\\" targetRef=\\\"task_approve\\\"><conditionExpression>approved == true</conditionExpression></sequenceFlow>\\n    <sequenceFlow id=\\\"flow_reject\\\" sourceRef=\\\"gw\\\" targetRef=\\\"task_reject\\\"/>\\n    <sequenceFlow id=\\\"f5\\\" sourceRef=\\\"task_approve\\\" targetRef=\\\"end_ok\\\"/>\\n    <sequenceFlow id=\\\"f6\\\" sourceRef=\\\"task_reject\\\" targetRef=\\\"end_ko\\\"/>\\n  </process>\\n</definitions>\"\n}"
            }
          }
        },
        {
          "name": "3. Start Instance",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('instance_id', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/process-instances",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "process-instances"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"org_id\": \"{{org_id}}\",\n  \"definition_id\": \"{{definition_id}}\"\n}"
            }
          }
        },
        {
          "name": "4. List Tasks (pick up Review task)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const items = pm.response.json().items;",
                  "  if (items && items.length > 0) {",
                  "    pm.collectionVariables.set('task_id', items[0].id);",
                  "    pm.test('task name is Review Request', () => pm.expect(items[0].name).to.eql('Review Request'));",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/tasks",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks"]
            }
          }
        },
        {
          "name": "5a. Complete Review — approved=true (→ Approve branch)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/{{task_id}}/complete",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "{{task_id}}", "complete"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"variables\": [\n    { \"name\": \"approved\", \"value_type\": \"boolean\", \"value\": true }\n  ]\n}"
            }
          }
        },
        {
          "name": "5b. Complete Review — approved=false (→ default/Reject branch)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/{{task_id}}/complete",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "{{task_id}}", "complete"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"variables\": [\n    { \"name\": \"approved\", \"value_type\": \"boolean\", \"value\": false }\n  ]\n}"
            }
          }
        },
        {
          "name": "6. List Tasks (confirm next task appeared)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const items = pm.response.json().items;",
                  "  if (items && items.length > 0) {",
                  "    pm.collectionVariables.set('task_id', items[0].id);",
                  "    pm.test('next task is Approve or Reject', () => {",
                  "      pm.expect(items[0].name).to.be.oneOf(['Approve', 'Reject']);",
                  "    });",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/tasks",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks"]
            }
          }
        },
        {
          "name": "7. Get Instance (confirm still running)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/process-instances/{{instance_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "process-instances", "{{instance_id}}"]
            }
          }
        }
      ]
    }
  ]
}
