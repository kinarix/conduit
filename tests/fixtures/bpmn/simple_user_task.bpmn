<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             id="Definitions_2"
             targetNamespace="http://conduit.io/schema/bpmn">
  <process id="simple_user_task" name="Simple User Task" isExecutable="true">
    <startEvent id="start_1" name="Start"/>
    <userTask id="task_review" name="Review Order"/>
    <endEvent id="end_1" name="End"/>
    <sequenceFlow id="flow_1" sourceRef="start_1" targetRef="task_review"/>
    <sequenceFlow id="flow_2" sourceRef="task_review" targetRef="end_1"/>
  </process>
</definitions>
