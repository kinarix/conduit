<!-- Contains an eventBasedGateway — unsupported.
     Parser must reject this with UnsupportedElement("eventBasedGateway"). -->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             id="Definitions_5"
             targetNamespace="http://conduit.io/schema/bpmn">
  <process id="ebg_process" name="Event Based GW Process" isExecutable="true">
    <startEvent id="start_1" name="Start"/>
    <eventBasedGateway id="gw_1" name="Event Based GW"/>
    <endEvent id="end_1" name="End"/>
    <sequenceFlow id="flow_1" sourceRef="start_1" targetRef="gw_1"/>
    <sequenceFlow id="flow_2" sourceRef="gw_1"    targetRef="end_1"/>
  </process>
