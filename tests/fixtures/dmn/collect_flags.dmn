<?xml version="1.0" encoding="UTF-8"?>
<!-- COLLECT hit policy: all matching rules returned as list. -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="collect_flags_defs"
             name="Collect Flags">
  <decision id="collect-flags" name="Collect Flags">
    <decisionTable hitPolicy="COLLECT">
      <input id="i_category" label="Category">
        <inputExpression><text>category</text></inputExpression>
      </input>
      <output id="o_flag" name="flag" label="Flag"/>
      <rule id="r1">
        <inputEntry><text>"premium","enterprise"</text></inputEntry>
        <outputEntry><text>"priority-support"</text></outputEntry>
      </rule>
      <rule id="r2">
        <inputEntry><text>"enterprise"</text></inputEntry>
        <outputEntry><text>"dedicated-account-manager"</text></outputEntry>
      </rule>
      <rule id="r3">
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"standard-support"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
